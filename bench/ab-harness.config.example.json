{
  "workload": {
    "id": "agent-teams-economics-ab",
    "description": "Matched workload A/B run across native Claude Agent Teams/subagent flow and Lead workflows.",
    "prompt_file": "workloads/README-workload-prompt.md",
    "comparison_target": "claude_agent_teams_subagent_workflow",
    "evidence_tier": "production_measured"
  },
  "trials": 8,
  "timeout_seconds": 3600,
  "confidence_level": 0.95,
  "bootstrap_iterations": 5000,
  "seed": 424242,
  "usage_window_tokens": 220000,
  "claim_policy": {
    "min_trials_for_savings_claim": 5
  },
  "telemetry": {
    "agent_metrics_jsonl": "~/.claude/hooks/session-state/agent-metrics.jsonl",
    "activity_jsonl": "~/.claude/terminals/activity.jsonl",
    "conflicts_jsonl": "~/.claude/terminals/conflicts.jsonl",
    "results_dir": "~/.claude/terminals/results",
    "transcript_roots": [
      "~/.claude"
    ],
    "transcript_include_regex": "transcript.*\\.jsonl$",
    "transcript_max_depth": 10,
    "attribution_policy": "strict_run_trial_path"
  },
  "paths": {
    "native": {
      "enabled": true,
      "command": "bash bench/workloads/run-native-subagent-workflow.sh",
      "extra_env": {
        "AB_WORKLOAD_RUN_MODE": "live",
        "AB_WORKLOAD_ALLOW_MOCK_FALLBACK": "0",
        "AB_NATIVE_SUBAGENT_WORKFLOW_CMD": ""
      }
    },
    "lead_coordinator": {
      "enabled": true,
      "command": "bash bench/workloads/run-lead-coordinator-workflow.sh",
      "extra_env": {
        "AB_WORKLOAD_RUN_MODE": "live",
        "AB_WORKLOAD_ALLOW_MOCK_FALLBACK": "0",
        "AB_LEAD_COORDINATOR_WORKFLOW_CMD": ""
      }
    },
    "lead_overlay": {
      "enabled": false,
      "command": "bash bench/workloads/run-lead-overlay-workflow.sh",
      "extra_env": {
        "AB_WORKLOAD_RUN_MODE": "live",
        "AB_WORKLOAD_ALLOW_MOCK_FALLBACK": "0",
        "AB_LEAD_OVERLAY_WORKFLOW_CMD": ""
      }
    }
  }
}
