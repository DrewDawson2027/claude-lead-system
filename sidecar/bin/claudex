#!/usr/bin/env bash
set -euo pipefail

CLAUDE_DIR="${CLAUDE_DIR:-$HOME/.claude}"
SIDECAR_DIR="$CLAUDE_DIR/lead-sidecar"
RUNTIME_DIR="$SIDECAR_DIR/runtime"
PORT_FILE="$RUNTIME_DIR/sidecar.port"
LOCK_FILE="$RUNTIME_DIR/sidecar.lock"
LOG_FILE="$SIDECAR_DIR/logs/sidecar.out.log"
MODE="${LEAD_SIDECAR_MODE:-full}"
OPEN_DASHBOARD=0
SIDECAR_ONLY=0
NO_SIDECAR=0
NATIVE_ENABLE="${LEAD_SIDECAR_NATIVE_ENABLE:-}"
NATIVE_BRIDGE_AUTOSTART="${LEAD_SIDECAR_NATIVE_BRIDGE_AUTOSTART:-}"
NODE_BIN="${NODE_BIN:-}"

if [[ -z "$NODE_BIN" ]]; then
  NODE_BIN="$(command -v node || true)"
fi
if [[ -z "$NODE_BIN" ]]; then
  for candidate in /opt/homebrew/bin/node /usr/local/bin/node /usr/bin/node; do
    if [[ -x "$candidate" ]]; then
      NODE_BIN="$candidate"
      break
    fi
  done
fi

show_recovery_help() {
  echo "Advanced recovery: $SIDECAR_DIR/bin/sidecarctl doctor" >&2
  echo "Startup log: $LOG_FILE" >&2
  if [[ -f "$SIDECAR_DIR/logs/npm-install.log" ]]; then
    echo "Install log: $SIDECAR_DIR/logs/npm-install.log" >&2
  fi
}

usage() {
  local advanced="${1:-0}"
  cat <<USAGE
Usage: claudex [--open-dashboard] [--] [claude args...]

Blessed default:
  Starts the standard Lead flow, syncs Claude settings,
  gets Lead ready in the background, then launches Claude.
  Next step: type /lead.

Common options:
  --open-dashboard  Open the Lead dashboard after startup
  --help-advanced   Show advanced launch options
USAGE
  if [[ "$advanced" = "1" ]]; then
    cat <<USAGE

Advanced options:
  --sidecar-only
  --mode full|hybrid|lite
  --native | --no-native
  --bridge-autostart | --no-bridge-autostart
  --no-sidecar
USAGE
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --mode)
      MODE="$2"; shift 2 ;;
    --open-dashboard)
      OPEN_DASHBOARD=1; shift ;;
    --sidecar-only)
      SIDECAR_ONLY=1; shift ;;
    --native)
      NATIVE_ENABLE=1; shift ;;
    --no-native)
      NATIVE_ENABLE=0; shift ;;
    --bridge-autostart)
      NATIVE_BRIDGE_AUTOSTART=1; shift ;;
    --no-bridge-autostart)
      NATIVE_BRIDGE_AUTOSTART=0; shift ;;
    --no-sidecar)
      NO_SIDECAR=1; shift ;;
    --help-advanced)
      usage 1; exit 0 ;;
    --help|-h)
      usage; exit 0 ;;
    --)
      shift; break ;;
    *)
      break ;;
  esac
done

case "$MODE" in
  full|hybrid|lite) ;;
  *)
    echo "Invalid --mode: $MODE (expected full|hybrid|lite)" >&2
    exit 1 ;;
esac

ensure_sidecar_running() {
  mkdir -p "$RUNTIME_DIR" "$SIDECAR_DIR/logs" "$SIDECAR_DIR/state"
  local need_start=1
  local sidecar_pid=""
  if [[ -f "$LOCK_FILE" ]]; then
    local pid
    pid=$(python3 - <<PY 2>/dev/null
import json
p="$LOCK_FILE"
try:
    print(json.load(open(p)).get('pid',''))
except Exception:
    print('')
PY
)
    if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null && [[ -f "$PORT_FILE" ]]; then
      need_start=0
    else
      rm -f "$LOCK_FILE" "$PORT_FILE"
    fi
  fi

  if [[ "$need_start" -eq 1 ]]; then
    rm -f "$PORT_FILE" "$LOCK_FILE"
    local tsx_bin="$SIDECAR_DIR/node_modules/.bin/tsx"
    local tsx_module="$SIDECAR_DIR/node_modules/tsx/dist/cli.mjs"
    local sidecar_entry="$SIDECAR_DIR/server/index.js"
    if [[ ! -x "$tsx_bin" ]] && [[ ! -f "$tsx_module" ]]; then
      echo "Lead background-service dependency missing: tsx is not installed in $SIDECAR_DIR." >&2
      echo "Re-run install.sh or run npm install in $SIDECAR_DIR." >&2
      if [[ -f "$SIDECAR_DIR/logs/npm-install.log" ]]; then
        echo "--- lead install log (tail) ---" >&2
        tail -40 "$SIDECAR_DIR/logs/npm-install.log" >&2 || true
      fi
      show_recovery_help
      return 1
    fi
    if [[ ! -f "$sidecar_entry" ]]; then
      echo "Lead background-service entry missing: $sidecar_entry" >&2
      show_recovery_help
      return 1
    fi
    local -a tsx_cmd
    if [[ -x "$tsx_bin" ]]; then
      if [[ -z "$NODE_BIN" ]]; then
        echo "Lead background-service dependency missing: node is not available for tsx." >&2
        show_recovery_help
        return 1
      fi
      tsx_cmd=("$NODE_BIN" "$tsx_module" --tsconfig "$SIDECAR_DIR/tsconfig.json" "$sidecar_entry")
    else
      if [[ -z "$NODE_BIN" ]]; then
        echo "Lead background-service dependency missing: node is not available." >&2
        show_recovery_help
        return 1
      fi
      tsx_cmd=("$NODE_BIN" "$tsx_module" --tsconfig "$SIDECAR_DIR/tsconfig.json" "$sidecar_entry")
    fi
    printf '[%s] starting Lead background service (mode=%s)\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" "$MODE" >> "$LOG_FILE"
    printf '[%s] launch command: %s\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" "${tsx_cmd[*]}" >> "$LOG_FILE"
    nohup env \
      LEAD_SIDECAR_AUTOSTART=1 \
      LEAD_SIDECAR_NATIVE_ENABLE="${NATIVE_ENABLE:-${LEAD_SIDECAR_NATIVE_ENABLE:-0}}" \
      LEAD_SIDECAR_NATIVE_BRIDGE_AUTOSTART="${NATIVE_BRIDGE_AUTOSTART:-${LEAD_SIDECAR_NATIVE_BRIDGE_AUTOSTART:-1}}" \
      "${tsx_cmd[@]}" >> "$LOG_FILE" 2>&1 &
    sidecar_pid="$!"
    disown || true
    local i
    for i in {1..100}; do
      [[ -f "$PORT_FILE" ]] && break
      if [[ -n "$sidecar_pid" ]] && ! kill -0 "$sidecar_pid" 2>/dev/null; then
        break
      fi
      sleep 0.2
    done
    if [[ ! -f "$PORT_FILE" ]]; then
      echo "Lead background service failed to start (no readiness file created)." >&2
      if [[ -n "$sidecar_pid" ]] && ! kill -0 "$sidecar_pid" 2>/dev/null; then
        echo "Background service exited before reporting readiness." >&2
      fi
      if [[ -f "$LOG_FILE" ]]; then
        echo "--- lead startup log (tail) ---" >&2
        tail -40 "$LOG_FILE" >&2 || true
      fi
      show_recovery_help
      return 1
    fi
  fi
}

open_dashboard() {
  if [[ -f "$PORT_FILE" ]]; then
    local port
    port=$(python3 - <<PY 2>/dev/null
import json
try:
    print(json.load(open("$PORT_FILE")).get('port',''))
except Exception:
    print('')
PY
)
    if [[ -n "${port:-}" ]]; then
      if command -v open >/dev/null 2>&1; then open "http://127.0.0.1:${port}/" >/dev/null 2>&1 || true; fi
      echo "Lead dashboard: http://127.0.0.1:${port}/"
    fi
  fi
}

if [[ -x "$SIDECAR_DIR/bin/merge-settings.mjs" ]]; then
  if [[ -z "$NODE_BIN" ]]; then
    echo "Lead settings sync failed: node is not available." >&2
    show_recovery_help
  elif ! "$NODE_BIN" "$SIDECAR_DIR/bin/merge-settings.mjs" --mode "$MODE" --quiet; then
    echo "Lead settings sync failed for mode=$MODE. /lead may not be fully wired." >&2
    show_recovery_help
  fi
fi

if [[ "$NO_SIDECAR" -ne 1 ]]; then
  ensure_sidecar_running
fi

if [[ "$OPEN_DASHBOARD" -eq 1 ]]; then
  open_dashboard
fi

if [[ "$NO_SIDECAR" -ne 1 ]] && [[ "${NATIVE_ENABLE:-0}" = "1" ]]; then
  if [[ -x "$SIDECAR_DIR/bin/sidecarctl" ]]; then
    "$SIDECAR_DIR/bin/sidecarctl" native-probe >/dev/null 2>&1 || true
    if [[ "${NATIVE_BRIDGE_AUTOSTART:-1}" = "1" ]]; then
      "$SIDECAR_DIR/bin/sidecarctl" bridge ensure >/dev/null 2>&1 || true
    fi
  fi
fi

if [[ "$SIDECAR_ONLY" -eq 1 ]]; then
  exit 0
fi

if command -v claude >/dev/null 2>&1; then
  exec claude "$@"
fi

echo "claude binary not found in PATH. Lead launcher completed, but Claude CLI is unavailable. Install Claude CLI or launch Claude normally." >&2
exit 1
