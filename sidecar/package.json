{
  "name": "lead-sidecar",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Local sidecar for Claude Lead System",
  "scripts": {
    "start": "tsx --tsconfig ./tsconfig.json ./server/index.js",
    "tui": "node ui-tui/index.js",
    "test": "tsx --test test/*.test.mjs",
    "coverage:sidecar": "npx c8 --reporter=text --reporter=html tsx --test test/*.test.mjs",
    "typecheck": "node ./bin/typecheck-ci.mjs",
    "typecheck:raw": "tsc --noEmit -p ./tsconfig.typecheck.json"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "tsx": "^4.20.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.9.3"
  }
}
